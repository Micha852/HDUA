@{
    Layout = "~/Views/Shared/layau2.cshtml";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <title>HDUA</title>
    <style>
        body{
            background-image: url('https://mdbootstrap.com/img/Photos/Others/images/78.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            height: 100vh;
        }
    </style>
</head>
<body>
    <div class="position-absolute top-50 start-50 translate-middle" id="aaa">

        <div class="row text-center">
            <a href="@Url.Action("Principal", "Principal")" class="fs-4"><samp>Búsqueda específica</samp><i class='bx bx-search'></i></a>
        </div>

        <div class="row">
            <form action="/" method="post" id="parametros" class="me-5">
                <div class="row">
                    <div class="col m-5">
                        <select class="form-select mt-5" aria-label="Default select example">
                            <option selected><samp>Orden</samp></option>
                            <option value="1"></option>
                        </select>
                        <select class="form-select mt-5" aria-label="Default select example">
                            <option selected>Especie</option>
                            <option value="1"></option>
                        </select>
                        <select class="form-select mt-5" aria-label="Default select example">
                            <option selected>Género</option>
                            <option value="1"></option>
                        </select>
                    </div>

                    <div class="col m-5">
                        <select class="form-select mt-5" aria-label="Default select example">
                            <option selected>Clase</option>
                            <option value="1"></option>
                        </select>
                        <select class="form-select mt-5" aria-label="Default select example">
                            <option selected>Familia</option>
                            <option value="1"></option>
                        </select>
                        <select class="form-select mt-5" aria-label="Default select example">
                            <option selected>Departamento</option>
                            <option value="1"></option>
                        </select>
                    </div>
                </div>

                <div class="row text-center mt-5">
                    <button class="btn-outline-dark" type="submit" id="button-addon1" formaction="@Url.Action("Resultado", "Resultado")"><samp>Buscar</samp></button>
                </div>
            </form>


        </div>

        
        
    </div>
</body>
</html>