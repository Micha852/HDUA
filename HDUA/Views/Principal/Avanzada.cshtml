@{
    Layout = "~/Views/Shared/layau2.cshtml";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <title>HDUA</title>
    <style>
        body{
            background-image: url('https://mdbootstrap.com/img/Photos/Others/images/78.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            height: 100vh;
        }
    </style>
</head>
<body>
    <div class="position-absolute top-50 start-50 translate-middle" id="aaa">

        <div class="col text-center">
            <a href="@Url.Action("Principal", "Principal")" class="fs-4" style="background-color: rgba(255, 255, 255, 0.6);"><samp>Búsqueda específica</samp><i class='bx bx-search'></i></a>
        </div>
        <samp>
            <div class="row">
                <form action="/" method="post" id="parametros" class="me-5">
                    <div class="row">
                        <div class="col m-5">
                            <h5 style="color: white;">Orden ↓<h5/>
                            <select class="form-select mt-2" name="sorden" aria-label="Default select example">
                                <option selected>Seleccione</option>
                                @foreach (String i in @ViewBag.lorden)
                                {
                                    <option>
                                        @i
                                    </option>
                                }
                            </select>
                            <h5 class="mt-5" style="color: white;">Especie ↓<h5/>
                            <select class="form-select mt-2" name="sespecie" aria-label="Default select example">
                                <option selected>Seleccione</option>
                                @foreach (String i in @ViewBag.lespecie)
                                {
                                    <option>
                                        @i
                                    </option>
                                }
                            </select>
                            <h5 class="mt-5" style="color: white;">Género ↓<h5/>
                            <select class="form-select mt-2" name="sgenero" aria-label="Default select example">
                                <option selected>Seleccione</option>
                                @foreach (String i in @ViewBag.lgenero)
                                {
                                    <option>
                                        @i
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="col m-5">
                            <h5 style="color: white;">Clase ↓<h5/>
                            <select class="form-select mt-2" name="sclase" aria-label="Default select example">
                                <option selected>Seleccione</option>
                                @foreach (String i in @ViewBag.lclase)
                                {
                                    <option>
                                        @i
                                    </option>
                                }
                            </select>
                            <h5 class="mt-5" style="color: white;">Familia ↓<h5/>
                            <select class="form-select mt-2" name="sfamilia" aria-label="Default select example">
                                <option selected>Seleccione</option>
                                @foreach (String i in @ViewBag.lfamilia)
                                {
                                    <option>
                                        @i
                                    </option>
                                }
                            </select>
                            <h5 class="mt-5" style="color: white;">Departamento ↓<h5/>
                            <select class="form-select mt-2" name="sdepa" aria-label="Default select example">
                                <option selected>Seleccione</option>
                                @foreach (String i in @ViewBag.ldepartamento)
                                {
                                    <option>
                                        @i
                                    </option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="col text-center mt-3">
                        <button class="btn btn-outline-light px-3 py-2" type="submit" id="button-addon1" formaction="@Url.Action("Resultado", "Principal")" name="btnParametros">
                            <samp>Buscar</samp>
                        </button>
                    </div>

                </form>
            </div>
        </samp>
        
    </div>
</body>
</html>