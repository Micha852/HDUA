    <!DOCTYPE html>
    <html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Tu Página</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="shortcut icon" href="~/img/planta.ico" type="image/x-icon"/>

        <style>
        body {
            background-image: null;
        }
        </style>
    </head>
    <body>

        @RenderBody()

    <footer class="bg-transparent border-top fixed-bottom">
        <div class="container-fluid py-3" style="background-color:#C2E6D6">
                <div class="row">
                    <div class="col-4 d-flex align-items-center">
                        <img src="~/img/LOGO_UDLA.png" alt="Logo" width="80" height="80">
                    </div>

                    <div class="col-4 d-flex justify-content-center align-items-center">
                    <samp>© Todos los derechos reservados</samp>
                    </div>

                    @if (ViewBag.IsLoginView == true )
                    {
                        <div class="col-4 d-flex align-items-center">
                            <img src="~/img/LOGO_UDLA.png" alt="Logo" width="80" height="80">
                            
                        </div>
                    }
                    else
                    {
                        <div class="col-4 d-flex justify-content-end align-items-center">
                            <img src="~/img/person.png" alt="Ícono de usuario" width="80" height="80">
                            <a href="@Url.Action("Login", "Login")"><samp> Ingresar al sistema</samp></a>
                        </div>
                    }
                </div>
                </div>
            </div>
        </footer>

    </body> 
    </html>
