<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tu Página</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <header class="bg-transparent">
        <nav class="navbar navbar-expand-lg align-items-center justify-content-center text-center" style="background-color: rgba(255, 255, 255, 0.5);">
            <div class="container-fluid align-items-center justify-content-center text-center">
                    <div class="col-sm-6 d-flex align-items-center justify-content-center text-center">
                        <img src="~/img/planta.png" alt="Ícono" style="height: 40px;">
                        <p class="fs-3"><samp>Herbario Digital Enrique Forero</samp></p>
                        <img src="~/img/planta.png" alt="Ícono" style="height: 40px;">
                    </div>
                </div>
            </div>
        </nav>
    </header>   

    @RenderBody()

    <footer class="bg-transparent border-top fixed-bottom">
        <div class="container-fluid py-3" style="background-color:#C2E6D6">
            <div class="row">

                <div class="col-4 d-flex align-items-center">
                    <img src="~/img/LOGO_UDLA.png" alt="Logo" width="80" height="80">
                </div>

                <div class="col-4 d-flex justify-content-center align-items-center">
                    <samp>© Todos los derechos reservados</samp>
                </div>

                <div class="col-4 d-flex justify-content-end align-items-center">
                    <img src="~/img/LOGO_UDLA.png" alt="Logo" width="80" height="80">
                </div>

            </div>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

</body>
</html>