@{
    Layout = "~/Views/Shared/layau2.cshtml";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/5.3.3/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/5.3.3/js/bootstrap.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <title>HDUA</title>
    <style>
        body {
            background-image: url('https://mdbootstrap.com/img/Photos/Others/images/78.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            height: 100vh;
        }

    </style>
</head>

<body>
    <samp>
    <div class="row mt-5">
        <div class="col d-flex justify-content-end align-items-end">
            <h3>___________________________</h3>
        </div>

        <div class="col d-flex justify-content-center align-items-center" style="background-color: rgba(128, 128, 128, 0.5);">
            <h3 class="panel-heading">GENERADOR DE INFORMES</h3>
        </div>

        <div class="col d-flex justify-content-start align-items-start">
            <h3>___________________________</h3>
        </div>
    </div>

    <div class="row mt-3 justify-content-center">
        <div class="col-md-8" style="max-height: 235px; overflow-y: auto;">
            <table class="table table-striped table-hover mt-3" id="tablaUsuarios">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Descargar en .PDF</th>
                        <th>Descargar en .CSV</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td>Muestras por municipio</td>
                        <td>Este informe proporciona un análisis detallado de las muestras recolectadas en los municipios que contaron con nuestra presencia.</td>
                        <td>
                            <button type="button" class="btn btn-link btn-editar" id="btnDescargarPDF" onclick="window.location.href='@Url.Action("DescargarPDF1", "Admin")'">
                                <i class="fa-regular fa-file-pdf fa-beat" style="font-size: 2.5rem; color: #d80e0e"></i>
                            </button>
                        </td>
                        <td>
                            <button type="button" class="btn btn-link btn-editar" onclick="window.location.href='@Url.Action("DescargarEXCEL1", "Admin")'">
                                <i class="fa-regular fa-file-excel fa-beat" style="font-size: 2.5rem; color: #1f5127"></i>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="col mt-5 d-flex justify-content-center align-items-center flex-column">
        <div class="row-md-auto text-center">
            <img src="~/img/flechatras2.png" alt="Ícono" width="100" height="100">
        </div>
        <div class="row-md-auto text-center">
            <a href="@Url.Action("Principal", "Admin")" class="btn btn-outline-light" style="display: block; margin: 0 auto; color: lightgray"><samp>Volver</samp></a>
        </div>
    </div>

    </samp>
</body>

</html>