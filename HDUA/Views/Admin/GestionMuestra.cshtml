@{
    Layout = "~/Views/Shared/layau2.cshtml";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/5.3.3/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/5.3.3/js/bootstrap.min.js"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>

    <title>HDUA</title>
    <style>
        body {
            background-image: url('https://mdbootstrap.com/img/Photos/Others/images/78.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            height: 100vh;
        }

    </style>
</head>

<body>

    <div class="row mt-5">
        <div class="col d-flex justify-content-end align-items-end">
            <h3>___________________________</h3>
        </div>

        <div class="col d-flex justify-content-center align-items-center" style="background-color: rgba(128, 128, 128, 0.5);">
            <h3 class="panel-heading"><samp>GESTIÓN DE MUESTRAS</samp></h3>
        </div>

        <div class="col d-flex justify-content-start align-items-start">
            <h3>___________________________</h3>
        </div>
    </div>

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-6 border border-black">
                <div class="col d-flex justify-content-center align-items-center flex-column">
                    <form>
                        <div class="row-md-auto mt-3 text-center">
                            <input type="text" class="form-control rounded-pill border border-dark" placeholder="Nombre científico" aria-label="Example text with button addon" aria-describedby="button-addon1">
                        </div>

                        <div class="row-md-auto mt-3 text-center">
                            <a href="@Url.Action("", "")" class="btn btn-outline-light btn-sm" style="color: lightgray;"><samp>Buscar</samp></a>
                        </div>

                        <div class="row-md-auto mt-5 text-center">
                            <img src="~/img/muestra.jpg" class="img-thumbnail" alt="" style="width: 120px; height: 150px;">
                        </div>
                    </form>
                </div>
            </div>


            <div class="col-md-6 border border-black">
                <div class="col mt-5 d-flex justify-content-center align-items-center flex-column">
                    <div class="row-md-auto text-center">
                        <img src="~/img/añadir.png" alt="Ícono" width="100" height="100">
                    </div>
                    <div class="row-md-auto text-center">
                        <a href="@Url.Action("", "")" class="btn btn-outline-light" style="display: block; margin: 0 auto; color: lightgray" data-bs-toggle="modal" data-bs-target="#modalAñadirMuestra"><samp>Añadir muestra</samp></a>
                    </div>
                </div>

                <div class="col mt-5 d-flex justify-content-center align-items-center flex-column">
                    <div class="row-md-auto text-center">
                        <img src="~/img/flechatras2.png" alt="Ícono" width="100" height="100">
                    </div>
                    <div class="row-md-auto text-center">
                        <a href="@Url.Action("Principal", "Admin")" class="btn btn-outline-light" style="display: block; margin: 0 auto; color: lightgray"><samp>Volver</samp></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade mt-5" id="modalAñadirMuestra" tabindex="-1" aria-labelledby="modalAñadirMuestraLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalAñadirMuestraLabel"><samp>Añadir Muestra</samp></h5>
                    <button type="button" class="btn btn-outline-danger ms-auto" id="cerrarHistoria" data-bs-dismiss="modal" aria-label="Close"><samp>X</samp></button>
                </div>

                <div class="modal-body" style="background-color: #C2E6D6">
                    <div id="carouselExampleControls" class="carousel slide" data-bs-interval="false">
                        <div class="carousel-inner ">
                            <form action="/" method="post"></form>
                            <!-- Parte 1 -->
                            <div class="carousel-item active">
                                <div class="container">
                                    <div class="row">

                                        <h3 class="d-flex justify-content-center align-items-center"><samp>Generalidades</samp></h3>

                                        <div class="col me-5 ms-5">
                                            <div class="row mt-3">
                                                <input type="text" class="form-control" placeholder="Nombre científico" oninput="this.value = this.value.toUpperCase()">
                                            </div>
                                            <div class="row mt-3">
                                                <input type="text" class="form-control" placeholder="Nombre vulgar" oninput="this.value = this.value.toUpperCase()">
                                            </div>
                                            <div class="row mt-3">
                                                <label for="formFile" class="form-label"><samp>Seleccionar imágen de muestra</samp></label>
                                                <input class="form-control" type="file" id="formFile">
                                            </div>
                                            <div class="row mt-3">
                                                <label for="formFile" class="form-label"><samp>Fecha recolección</samp></label>
                                                <input type="date" class="form-control" id="fecharecolecccion">
                                            </div>
                                        </div>

                                        <div class="col me-5 ms-5">
                                            <div class="row mt-3">
                                                <select class="form-select">
                                                    <option selected>Tipo venación</option>
                                                </select>
                                            </div>

                                            <div class="row mt-3">
                                                <select class="form-select">
                                                    <option selected>Tipo forma</option>
                                                </select>
                                            </div>
                                            
                                            <div class="row mt-3">
                                                <select class="form-select">
                                                    <option selected>Tipo margen</option>
                                                </select>
                                            </div>
                                            
                                            <div class="row mt-3">
                                                <select class="form-select">
                                                    <option selected>Procedencia</option>
                                                </select>
                                            </div>
                                            
                                            <div class="row mt-3">
                                                <select class="form-select">
                                                    <option selected>Altura</option>
                                                </select>
                                            </div>
                                            
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Parte 2 -->
                            <div class="carousel-item">
                                <div class="container">
                                    <div class="row">

                                        <h3 class="d-flex justify-content-center align-items-center"><samp>Especificaciones</samp></h3>
                                        
                                        <div class="col me-5 ms-5">
                                            <div class="row mt-3">
                                                <select class="form-select">
                                                    <option selected>Clase</option>
                                                </select>
                                            </div>

                                            <div class="row mt-3">
                                                <select class="form-select">
                                                    <option selected>Especie</option>
                                                </select>
                                            </div>

                                            <div class="row mt-3">
                                                <select class="form-select">
                                                    <option selected>Géneron</option>
                                                </select>
                                            </div>

                                            <div class="row mt-3">
                                                <select class="form-select">
                                                    <option selected>Tipo Ubicación</option>
                                                </select>
                                            </div>

                                        </div>

                                        <div class="col me-5 ms-5">
                                            <div class="row mt-3">
                                                <select class="form-select">
                                                    <option selected>Orden</option>
                                                </select>
                                            </div>

                                            <div class="row mt-3">
                                                <select class="form-select">
                                                    <option selected>Familia</option>
                                                </select>
                                            </div>

                                            <div class="row mt-3">
                                                <select class="form-select">
                                                    <option selected>Departamento</option>
                                                </select>
                                            </div>

                                            <div class="row mt-3">
                                                <select class="form-select">
                                                    <option selected>Ubicación</option>
                                                </select>
                                            </div>

                                            <div class="row mt-3">
                                                <input type="text" class="form-control" placeholder="Coordenadas..." oninput="this.value = this.value.toUpperCase()">
                                            </div>

                                        </div>

                                    </div>
                                </div>
                            </div>

                            <!-- Parte 3 -->
                            <div class="carousel-item">
                                <div class="container">

                                    <h3 class="d-flex justify-content-center align-items-center"><samp>Asociar recolectores</samp></h3>
                                        
                                    
                                    <div class="row mt-3 ms-5 me-5">
                                        <div class="col-auto align-items-center justify-content: center">
                                            <i class='bx bx-search-alt'></i>
                                        </div>
                                        <div class="col-auto">
                                            <input type="text" class="form-control" id="buscar-recolector" placeholder="Buscar recolector">
                                        </div>
                                    </div>

                                    <table class="table table-striped table-hover mt-3">
                                        <thead>
                                            <tr>
                                                <th scope="col"><samp>Nombre</samp></th>
                                                <th scope="col"><samp>Muestras ligadas</samp></th>
                                                <th scope="col"><samp>Seleccionar</samp></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td></td>
                                                <td></td>
                                                <td>
                                                    <input type="checkbox">
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Controles del carrusel -->
                        <button class="carousel-control-prev btn btn-outline-success me-5" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>

                        <button class="carousel-control-next btn btn-outline-success ms-5" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>



                    </div>
                </div>

                <div class="modal-footer justify-content-between">
                    <button type="button" class="btn btn-outline-success" data-bs-dismiss="modal"><samp>Cancelar</samp></button>
                    <button type="button" class="btn btn-outline-success"><samp>Finalizar</samp></button>
                </div>

            </div>
        </div>
    </div>


</body>
</html>
