@{
    Layout = "~/Views/Shared/layau2.cshtml";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/5.3.3/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/5.3.3/js/bootstrap.min.js"></script>
    <title>HDUA</title>
    <style>
        body {
            background-image: url('https://mdbootstrap.com/img/Photos/Others/images/78.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            height: 100vh;
        }


    </style>
</head>

<body>
    <div class="row mt-5">
        <div class="col d-flex justify-content-end align-items-end">
            <h3>___________________________</h3>
        </div>

        <div class="col d-flex justify-content-center align-items-center" style="background-color: rgba(128, 128, 128, 0.5);">
            <h3 class="panel-heading"><samp>PANEL DE CONTROL DEL SISTEMA</samp></h3>
        </div>
        
        <div class="col d-flex justify-content-start align-items-start">
            <h3>___________________________</h3>
        </div>
    </div>

    <div class="container mt-5">
        <div class="row justify-content-center mt-5">
            <div class="col-md-8">
                <!-- Gestión de muestras -->
                <div class="border border-black mb-4 mt-5" style="background-color:#C2E6D6">
                    <div class="row align-items-center">
                        <div class="col d-flex justify-content-center align-items-center">
                            <img src="~/img/gestionmuestra.png" alt="Ícono" width="80" height="80">
                        </div>
                        <div class="col d-flex justify-content-center align-items-center">
                            <samp>Gestión de muestras botánicas</samp>
                        </div>
                        <div class="col d-flex flex-column justify-content-center align-items-center">
                            <img src="~/img/seleccionar.png" alt="Ícono" width="50" height="50">
                            <div class="mt-0">
                                <a href="@Url.Action("GestionMuestra", "Admin")"><samp>Seleccionar</samp></a>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Gestión de usuarios -->
                <div class="border border-black mb-4" style="background-color:#C2E6D6">
                    <div class="row align-items-center">
                        <div class="col d-flex justify-content-center align-items-center">
                            <img src="~/img/users.png" alt="Ícono" width="80" height="80">
                        </div>
                        <div class="col d-flex justify-content-center align-items-center">
                            <samp>Gestión de usuarios registrados</samp>
                        </div>
                        <div class="col d-flex flex-column justify-content-center align-items-center">
                            <img src="~/img/seleccionar.png" alt="Ícono" width="50" height="50">
                            <div class="mt-0">
                                <a href="@Url.Action("", "")"><samp>Seleccionar</samp></a>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Gestión de informes -->
                <div class="border border-black" style="background-color:#C2E6D6">
                    <div class="row align-items-center">
                        <div class="col d-flex justify-content-center align-items-center">
                            <img src="~/img/informe.png" alt="Ícono" width="80" height="80">
                        </div>
                        <div class="col d-flex justify-content-center align-items-center">
                            <samp>Generar informes parametrizados</samp>
                        </div>
                        <div class="col d-flex flex-column justify-content-center align-items-center">
                            <img src="~/img/seleccionar.png" alt="Ícono" width="50" height="50">
                            <div class="mt-0">
                                <a href="@Url.Action("", "")"><samp>Seleccionar</samp></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>




</body>


</html>