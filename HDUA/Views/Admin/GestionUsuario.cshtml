@{
    Layout = "~/Views/Shared/layau2.cshtml";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/5.3.3/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/5.3.3/js/bootstrap.min.js"></script>

    <title>HDUA</title>
    <style>
        body {
            background-image: url('https://mdbootstrap.com/img/Photos/Others/images/78.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            height: 100vh;
        }

    </style>
</head>

<body>
    <div class="row mt-5">
        <div class="col d-flex justify-content-end align-items-end">
            <h3>___________________________</h3>
        </div>

        <div class="col d-flex justify-content-center align-items-center" style="background-color: rgba(128, 128, 128, 0.5);">
            <h3 class="panel-heading"><samp>GESTIÓN DE USUARIOS</samp></h3>
        </div>

        <div class="col d-flex justify-content-start align-items-start">
            <h3>___________________________</h3>
        </div>
    </div>

    <div class="row mt-3 ms-5 justify-content-center">
        <div class="col-auto">
            <input type="text" class="form-control" id="buscar-recolector" placeholder="Buscar usuario">
        </div>
        <div class="col-auto">
            <i class='bx bx-search-alt' style="font-size: 1.5rem;"></i>
        </div>
    </div>

    <div class="row mt-3 justify-content-center">
        <div class="col-md-8" style="max-height: 400px; overflow-y: auto;">
            <table class="table table-striped table-hover mt-3">
                <thead>
                    <tr>
                        <th scope="col"><samp>Nombre completo</samp></th>
                        <th scope="col"><samp>Edad</samp></th>
                        <th scope="col"><samp>¿Recolector?</samp></th>
                        <th scope="col"><samp>Rol</samp></th>
                        <th scope="col"><samp>Estado</samp></th>
                        <th scope="col"><samp>Editar</samp></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td>
                            <button type="button" class="btn btn-link btn-editar">
                                <i class='bx bxs-edit' style="font-size: 1.5rem;"></i>
                            </button>

                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="col mt-5 d-flex justify-content-center align-items-center flex-column">
        <div class="row-md-auto text-center">
            <img src="~/img/flechatras2.png" alt="Ícono" width="100" height="100">
        </div>
        <div class="row-md-auto text-center">
            <a href="@Url.Action("Principal", "Admin")" class="btn btn-outline-light" style="display: block; margin: 0 auto; color: lightgray"><samp>Volver</samp></a>
        </div>
    </div>

    
    <div class="modal fade mt-5" id="modalEditarUsuario" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel"><samp>Editar Usuario</samp></h5>
                    <button type="button" class="btn btn-outline-danger ms-auto" id="cerrarEditarUser" data-bs-dismiss="modal" aria-label="Close"><samp>X</samp></button>
                </div>
                <div class="modal-body">
                    <form id="formEditarUsuario">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="selectRol" class="form-label"><samp>Rol</samp></label>
                                    <select class="form-select" id="selectRol" name="rol">
                                        <option value="1"></option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="selectEstado" class="form-label"><samp>Estado</samp></label>
                                    <select class="form-select" id="selectEstado" name="estado">
                                        <option value="activo"></option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer justify-content-between">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><samp>Cancelar</samp></button>
                    <button type="button" class="btn btn-primary" id="btnGuardarUsuario"><samp>Finalizar</samp></button>
                </div>
            </div>
        </div>
    </div>



    <script>
        $(document).ready(function () {
            $('.btn-editar').click(function () {
                $('#modalEditarUsuario').modal('show');
            });

            // $('#btnGuardarUsuario').click(function () {
            //     $('#modalEditarUsuario').modal('hide');
            // });
        });
    </script>

</body>

</html>